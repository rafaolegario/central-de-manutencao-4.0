#That's enviroments variables, so any security issue introduced.
#Arbitraty values, but you can send a message in WhatsApp requesting the .env if it's needed

# PostgreSQL
POSTGRES_CONTAINER=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_PORT=

# Admin user (seeded automatically on first run)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# JWT — use a long random string (minimum 32 characters)
JWT_SIGNING_KEY=
JWT_EXPIRES_MINUTES=


